{
  "name": "kubedeck",
  "version": "2.0.0-alpha.8",
  "private": true,
  "workspaces": [
    "apps/desktop",
    "packages/shared-types",
    "packages/ui"
  ],
  "scripts": {
    "dev": "npm --workspace apps/desktop run dev",
    "build": "npm --workspace apps/desktop run build",
    "typecheck": "npm --workspace apps/desktop run typecheck",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-portable-windows.ps1",
    "test:gateway": "npm --workspace apps/desktop run build && npm --workspace apps/desktop run test:gateway"
  },
  "devDependencies": {
    "7zip-bin": "^5.2.0"
  }
}
