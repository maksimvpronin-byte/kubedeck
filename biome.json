{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": ["apps/desktop/src/**/*", "apps/desktop/tests/**/*", "scripts/**/*", "*.json"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 200
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnreachable": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useHookAtTopLevel": "error"
      },
      "suspicious": {
        "noDuplicateObjectKeys": "error",
        "noDuplicateParameters": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["apps/desktop/src/renderer/hooks/usePodDrawerResourceLifecycle.ts", "apps/desktop/src/renderer/hooks/useResourceWatch.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "useExhaustiveDependencies": "error"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
