# Keep source and configuration files byte-identical across macOS and Windows.
* text=auto eol=lf

# Windows-native command files use the platform-standard line ending.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Unix shell entrypoints must remain executable with LF line endings.
*.sh text eol=lf

# Never apply line-ending conversion to binary assets or release artifacts.
*.ico binary
*.icns binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.node binary
*.dll binary
*.exe binary
*.dmg binary
*.zip binary
